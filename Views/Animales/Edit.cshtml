@model AnimalFormDto
@{
    ViewData["Title"] = "Editar animal";
    int id = (int)ViewBag.Id;
}

<h1>Editar animal #@id</h1>

<form asp-action="Edit" asp-route-id="@id" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Especie" class="form-label"></label>
        <input asp-for="Especie" class="form-control" />
        <span asp-validation-for="Especie" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Sexo" class="form-label">Sexo (M o H)</label>
        <input asp-for="Sexo" class="form-control" maxlength="1" />
        <span asp-validation-for="Sexo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Reserva" class="form-label"></label>
        <input asp-for="Reserva" class="form-control" />
        <span asp-validation-for="Reserva" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Energia" class="form-label"></label>
        <input asp-for="Energia" class="form-control" type="number" />
        <span asp-validation-for="Energia" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
