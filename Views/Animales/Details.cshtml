@model Animal
@{
    ViewData["Title"] = "Detalle del animal";
}

<h1>Animal #@Model.Id</h1>

<dl class="row">
    <dt class="col-sm-2">Especie</dt>
    <dd class="col-sm-10">@Model.Especie</dd>

    <dt class="col-sm-2">Sexo</dt>
    <dd class="col-sm-10">@Model.Sexo</dd>

    <dt class="col-sm-2">Reserva</dt>
    <dd class="col-sm-10">@Model.Reserva</dd>

    <dt class="col-sm-2">Energia</dt>
    <dd class="col-sm-10">@Model.Energia</dd>

    <dt class="col-sm-2">Fecha alta</dt>
    <dd class="col-sm-10">@Model.FechaAlta.ToString("yyyy-MM-dd HH:mm")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Editar</a> |
<a asp-action="Index">Volver al listado</a>
